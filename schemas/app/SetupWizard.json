{
  "name": "SetupWizard",
  "label": "Setup Wizard",
  "isSingle": true,
  "isChild": false,
  "isSubmittable": false,
  "fields": [
    {
      "fieldname": "logo",
      "label": "Logo de la empresa",
      "fieldtype": "AttachImage",
      "section": "Empresa"
    },
    {
      "fieldname": "companyName",
      "label": "Nombre de la empresa",
      "placeholder": "Mi Empresa S.A. de C.V.",
