      "placeholder": "Mexico - Plan de Cuentas",
      "section": "Contabilidad",
      "required": true
    },
    {
      "fieldname": "fiscalYearStart",
      "label": "Inicio del año fiscal",
      "placeholder": "Inicio del año fiscal",
      "fieldtype": "Date",
      "section": "Contabilidad",
      "required": true
    },
    {
      "fieldname": "fiscalYearEnd",
      "label": "Fin del año fiscal",
      "placeholder": "Fin del año fiscal",
      "fieldtype": "Date",
      "section": "Contabilidad",
      "required": true
    },
    {
      "fieldname": "completed",
      "label": "Completado",
      "fieldtype": "Check",
      "hidden": true,
      "readOnly": true
    }
  ],
  "quickEditFields": [
    "fullname",
    "bankName",
    "country",
    "currency",
    "chartOfAccounts",
    "fiscalYearStart",
    "fiscalYearEnd"
