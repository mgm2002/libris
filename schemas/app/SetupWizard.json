      "required": true,
      "section": "Empresa"
    },
    {
      "fieldname": "fullname",
      "label": "Nombre completo",
      "fieldtype": "Data",
      "placeholder": "Juan García López",
      "required": true,
      "section": "Empresa"
    },
    {
      "fieldname": "email",
      "label": "Correo electrónico",
      "fieldtype": "Data",
      "placeholder": "juan@miempresa.com",
      "required": true,
      "section": "Empresa"
    },
    {
      "fieldname": "country",
      "label": "País",
      "fieldtype": "AutoComplete",
      "placeholder": "México",
      "section": "Localización",
      "required": true,
      "default": "Mexico",
      "readOnly": true
    },
    {
      "fieldname": "currency",
      "label": "Moneda",
      "fieldtype": "AutoComplete",
      "placeholder": "MXN",
      "section": "Localización",
      "required": true,
      "readOnly": true
    },
    {
      "fieldname": "bankName",
      "label": "Banco",
      "fieldtype": "Data",
      "placeholder": "BBVA / Banamex / Santander",
      "section": "Contabilidad",
      "required": true
